# ============================================================
# .gitignore para Jekyll — Grupo Scout Nyeri
# ============================================================

# Directorio de salida (generado por el comando jekyll build)
_site/

# Caché y metadatos de Jekyll
.jekyll-cache/
.jekyll-metadata

# Dependencias de Ruby (Bundler)
.bundle/
vendor/

# Archivos del sistema
.DS_Store
Thumbs.db

# Logs
*.log

# No ignoramos Gemfile.lock para asegurar que el entorno local
# sea idéntico al de despliegue si se usa un servidor propio,
# aunque GitHub Pages lo ignora al construir en sus servidores.
# Gemfile.lock
